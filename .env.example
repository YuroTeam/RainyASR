# RainyASR Environment Configuration
# Copy this file to .env and fill in your API keys

# DashScope (Aliyun) - ASR service
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ASR_MODEL=qwen3-asr-flash-filetrans

# DeepSeek - Translation service
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
TRANSLATE_MODEL=deepseek-chat

# Optional: Logfire observability (https://logfire.pydantic.dev)
# Leave empty to disable; set token to send logs to Logfire backend
LOGFIRE_TOKEN=
